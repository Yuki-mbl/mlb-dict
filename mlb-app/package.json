{
  "name": "mlb-dict-app",
  "version": "1.0.0",
  "private": true,
  "description": "メジャーリーグ野球用語 英和・和英辞典＆学習プレイ (iOS/Android wrapper)",
  "scripts": {
    "copyweb": "node copyweb.js",
    "sync": "npm run copyweb && npx cap sync ios",
    "sync:android": "npm run copyweb && npx cap sync android",
    "open:android": "npx cap open android",
    "icons": "npx @capacitor/assets generate --ios",
    "icons:android": "npx @capacitor/assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2"
  }
}
